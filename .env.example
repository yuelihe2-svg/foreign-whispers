# Host user — so Docker-created files are owned by you, not root
# Run: id -u && id -g   to find your values
UID=1000
GID=1000

# Hugging Face — required for speaker diarization (pyannote.audio)
# Get yours at https://huggingface.co/settings/tokens
HF_TOKEN=

# Logfire — optional, enables observability traces
# Get yours at https://logfire.pydantic.dev
LOGFIRE_TOKEN=
